<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/background" android:orientation="vertical">
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:fillViewport="true">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="126dp" android:background="@drawable/bg_card" android:gravity="center_vertical" android:orientation="horizontal" android:padding="24dp">
                <TextView android:id="@+id/tvAvatar" android:layout_width="72dp" android:layout_height="72dp" android:gravity="center" android:text="QM" android:textColor="@color/text_primary" android:textSize="24sp" android:textStyle="bold" />
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:id="@+id/tvName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Khách" android:textColor="@color/text_primary" android:textSize="22sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tvEmail" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="guest@quizmaster.vn" android:textColor="@color/text_secondary" android:textSize="14sp" />
                </LinearLayout>
                <TextView android:id="@+id/btnEdit" android:layout_width="48dp" android:layout_height="48dp" android:gravity="center" android:text="✎" android:textColor="@color/text_primary" android:textSize="27sp" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="86dp" android:gravity="center" android:orientation="horizontal">
                <TextView style="@style/ProfileStat" android:text="120&#10;Điểm" /><TextView style="@style/ProfileStat" android:text="5&#10;Streak" /><TextView style="@style/ProfileStat" android:text="12&#10;Bài thi" />
            </LinearLayout>
            <LinearLayout android:id="@+id/rowPersonal" style="@style/ProfileRow"><TextView style="@style/ProfileIcon" android:background="@drawable/bg_icon_blue" android:text="♙" /><TextView style="@style/ProfileRowText" android:text="Thông tin cá nhân&#10;Cập nhật hồ sơ" /><TextView style="@style/ProfileArrow" /></LinearLayout>
            <LinearLayout android:id="@+id/rowGoal" style="@style/ProfileRow"><TextView style="@style/ProfileIcon" android:background="@drawable/bg_icon_purple" android:text="⚑" /><TextView style="@style/ProfileRowText" android:text="Mục tiêu học tập&#10;20 câu/ngày" /><TextView style="@style/ProfileArrow" /></LinearLayout>
            <LinearLayout android:id="@+id/rowNotification" style="@style/ProfileRow"><TextView style="@style/ProfileIcon" android:background="@drawable/bg_icon_orange" android:text="♧" /><TextView style="@style/ProfileRowText" android:text="Thông báo&#10;Quản lý nhắc nhở" /><TextView style="@style/ProfileArrow" /></LinearLayout>
            <LinearLayout android:id="@+id/rowHistory" style="@style/ProfileRow"><TextView style="@style/ProfileIcon" android:background="@drawable/bg_icon_blue" android:text="◷" /><TextView style="@style/ProfileRowText" android:text="Lịch sử hoạt động&#10;Xem log học tập" /><TextView style="@style/ProfileArrow" /></LinearLayout>
            <LinearLayout android:id="@+id/rowAchievement" style="@style/ProfileRow"><TextView style="@style/ProfileIcon" android:background="@drawable/bg_icon_red" android:text="♙" /><TextView style="@style/ProfileRowText" android:text="Thành tích&#10;3 đã mở" /><TextView style="@style/ProfileArrow" /></LinearLayout>
            <TextView android:id="@+id/btnLogout" android:layout_width="match_parent" android:layout_height="62dp" android:layout_marginTop="18dp" android:gravity="center" android:text="⇥  Đăng xuất" android:textColor="#C83C3C" android:textSize="17sp" android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>
    <include layout="@layout/view_bottom_nav" />
</LinearLayout>
