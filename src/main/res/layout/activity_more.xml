<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/background" android:orientation="vertical">
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"><LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Thêm" style="@style/ScreenTitle" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:layout_marginBottom="28dp" android:text="Cài đặt và tùy chọn bổ sung" android:textColor="@color/text_secondary" android:textSize="16sp" />
        <LinearLayout android:id="@+id/rowDark" style="@style/ProfileRow"><TextView style="@style/ProfileIcon" android:background="@drawable/bg_icon_orange" android:text="☾" /><TextView android:id="@+id/tvDark" style="@style/ProfileRowText" android:text="Chế độ tối&#10;Đang tắt" /><androidx.appcompat.widget.SwitchCompat android:id="@+id/switchDark" android:layout_width="wrap_content" android:layout_height="wrap_content" /></LinearLayout>
        <LinearLayout android:id="@+id/rowPrivacy" style="@style/ProfileRow"><TextView style="@style/ProfileIcon" android:background="@drawable/bg_icon_blue" android:text="♢" /><TextView style="@style/ProfileRowText" android:text="Quyền riêng tư&#10;Quản lý dữ liệu cá nhân" /><TextView style="@style/ProfileArrow" /></LinearLayout>
        <LinearLayout android:id="@+id/rowAbout" style="@style/ProfileRow"><TextView style="@style/ProfileIcon" android:background="@drawable/bg_icon_purple" android:text="ⓘ" /><TextView style="@style/ProfileRowText" android:text="Về ứng dụng&#10;QuizMaster v1.0.0" /><TextView style="@style/ProfileArrow" /></LinearLayout>
        <LinearLayout android:id="@+id/rowHelp" style="@style/ProfileRow"><TextView style="@style/ProfileIcon" android:background="@drawable/bg_icon_green" android:text="?" /><TextView style="@style/ProfileRowText" android:text="Trợ giúp&#10;FAQ &amp; hỗ trợ" /><TextView style="@style/ProfileArrow" /></LinearLayout>
        <LinearLayout android:id="@+id/rowDelete" style="@style/ProfileRow"><TextView style="@style/ProfileIcon" android:background="@drawable/bg_icon_red" android:text="♲" /><TextView style="@style/ProfileRowText" android:text="Xóa dữ liệu&#10;Xóa toàn bộ lịch sử học tập" /><TextView style="@style/ProfileArrow" /></LinearLayout>
    </LinearLayout></ScrollView>
    <include layout="@layout/view_bottom_nav" />
</LinearLayout>
