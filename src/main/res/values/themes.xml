<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.QuizMaster" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple</item>
        <item name="colorPrimaryVariant">@color/purple_dark</item>
        <item name="colorSecondary">@color/green</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowActionModeOverlay">true</item>
    </style>
    <style name="NavItem">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:lineSpacingExtra">5dp</item>
        <item name="android:fontFamily">sans</item>
    </style>
    <style name="NavHomeItem" parent="NavItem">
        <item name="android:textColor">@color/purple</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">13sp</item>
    </style>
    <style name="ScreenTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="SectionTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">21sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="Label">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="ProfileStat">
        <item name="android:layout_width">0dp</item><item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item><item name="android:gravity">center</item>
        <item name="android:textColor">@color/text_primary</item><item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item><item name="android:lineSpacingExtra">6dp</item>
    </style>
    <style name="ProfileRow">
        <item name="android:layout_width">match_parent</item><item name="android:layout_height">94dp</item>
        <item name="android:layout_marginBottom">8dp</item><item name="android:background">@drawable/bg_card</item>
        <item name="android:gravity">center_vertical</item><item name="android:orientation">horizontal</item>
        <item name="android:paddingHorizontal">18dp</item>
    </style>
    <style name="ProfileIcon">
        <item name="android:layout_width">54dp</item><item name="android:layout_height">54dp</item>
        <item name="android:gravity">center</item><item name="android:textColor">@color/white</item>
        <item name="android:textSize">25sp</item>
    </style>
    <style name="ProfileRowText">
        <item name="android:layout_width">0dp</item><item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">16dp</item><item name="android:layout_weight">1</item>
        <item name="android:textColor">@color/text_primary</item><item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item><item name="android:lineSpacingExtra">5dp</item>
    </style>
    <style name="ProfileArrow">
        <item name="android:layout_width">30dp</item><item name="android:layout_height">match_parent</item>
        <item name="android:gravity">center</item><item name="android:text">›</item>
        <item name="android:textColor">@color/text_secondary</item><item name="android:textSize">36sp</item>
    </style>
    <style name="ProfileEdit">
        <item name="android:layout_width">match_parent</item><item name="android:layout_height">66dp</item>
        <item name="android:layout_marginTop">7dp</item><item name="android:background">@drawable/bg_input</item>
        <item name="android:paddingHorizontal">18dp</item><item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">17sp</item><item name="android:singleLine">true</item>
    </style>
    <style name="QuizAnswer">
        <item name="android:layout_width">match_parent</item><item name="android:layout_height">68dp</item>
        <item name="android:layout_marginBottom">12dp</item><item name="android:background">@drawable/bg_card</item>
        <item name="android:buttonTint">@color/purple</item><item name="android:gravity">center_vertical</item>
        <item name="android:paddingHorizontal">18dp</item><item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
    </style>
    <style name="ChoiceIcon">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginEnd">7dp</item>
        <item name="android:background">@drawable/bg_choice</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="ColorChoice">
        <item name="android:layout_width">42dp</item>
        <item name="android:layout_height">42dp</item>
        <item name="android:layout_marginEnd">14dp</item>
    </style>
    <style name="QuickAction">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:lineSpacingExtra">5dp</item>
    </style>
    <style name="SubjectTab">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">42dp</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:background">@drawable/bg_choice</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingHorizontal">18dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="IntroRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">42dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
    </style>
</resources>
